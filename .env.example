# Airtable (required for ingestion and API)
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=your_base_id

# Module 1: NDA + Deal Room (table names must match Airtable exactly)
AIRTABLE_TABLE_DEALS=Deals
AIRTABLE_TABLE_BRAND_DEAL_REQUESTS=Brand Deal Requests
AIRTABLE_TABLE_DEAL_ACTIVITY_LOG=Deal Activity Log
AIRTABLE_TABLE_DEAL_ROOM_DOCUMENTS=Deal Room Documents

# Module 2: Proposal submission history (snapshot per submit)
AIRTABLE_TABLE_PROPOSAL_SUBMISSIONS=Proposal Submissions

# Schema patch (patch-nda-deal-room-schema.js) requires Personal Access Token with:
#   schema.bases:read
#   schema.bases:write
# Data read/write uses standard data.records scopes (same as other API calls).

# Market Alerts tables (must match Airtable)
AIRTABLE_TABLE_MARKET_ALERTS=MarketAlerts
AIRTABLE_TABLE_USER_STATUS=UserAlertStatus

# Ingestion tuning
LOOKBACK_HOURS=24
MAX_ITEMS=100
MIN_PER_CATEGORY=8
MAX_LOOKBACK_HOURS=168

# Set to false to write to Airtable; true to log only (no writes)
DRY_RUN=false

# When GDELT fails: true = use RSS fallback then synthetic last resort
FALLBACK_SEED=false
# RSS fallback (optional; default = curated hospitality feeds)
# RSS_FEEDS=https://example.com/feed1,https://example.com/feed2
RSS_MAX_PER_FEED=25
RSS_TOTAL_TARGET=250
MAX_ARTICLE_AGE_DAYS=30
BOOTSTRAP=false

# Franchise Application (table must have Deal + Form Data)
# AIRTABLE_TABLE_FRANCHISE_APPLICATIONS=Franchise Applications
# AIRTABLE_FRANCHISE_APPLICATION_DEAL_FIELD=Deal
# AIRTABLE_FRANCHISE_APPLICATION_FORM_DATA_FIELD=Form Data

# My Deals fast mode (defaults in code; override here if needed)
MY_DEALS_USE_BATCHED_LINKED_FETCHES=1
MY_DEALS_USE_PARALLEL_BATCHED_LINKED_FETCHES=1
MY_DEALS_BATCH_FETCH_CHUNK_SIZE=10
MY_DEALS_BATCH_FETCH_DELAY_MS=100
MY_DEALS_PHASE_GAP_MS=100

# Third-party operator Service Offerings: legacy per-option checkbox columns (off by default; set 1 if your base still uses them)
# OPERATOR_SERVICE_GRANULAR_CHECKBOX_WRITES=0

# Operator Setup new-base writer feature flags
# 0/false = keep legacy writer as primary
OPERATOR_SETUP_USE_NEW_BASE_WRITER=0
# 1/true = run new-base writer in parallel while legacy path remains source of truth
OPERATOR_SETUP_NEW_BASE_SHADOW_WRITE=0
# 1/true = if new-base primary writer fails, continue with legacy writer path
OPERATOR_SETUP_NEW_BASE_FAIL_OPEN=0
